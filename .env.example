# Variáveis de ambiente do Sistema de Relatórios Naabsa (PRD §13).
# Copie para `.env` e preencha. NUNCA commitar o `.env` (está no .gitignore).

# === Supabase ===
SUPABASE_URL=
SUPABASE_ANON_KEY=          # apps/web (cliente)
SUPABASE_SERVICE_ROLE_KEY=  # apps/worker e rotas de serviço

# Espelho exposto ao browser pelo Next.js (mesmos valores de SUPABASE_URL/ANON_KEY).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Banco (pg-boss usa o Postgres do Supabase) ===
DATABASE_URL=

# === Geração de PDF (.docx nativo → LibreOffice) ===
APP_BASE_URL=               # usada pelo worker para buscar o logo NAABSA (ex.: http://app:3000)
SOFFICE_PATH=               # opcional: caminho do soffice (default detecta Windows/Linux)
LO_PROFILE_DIR=             # opcional: perfil do LibreOffice (worker); default ./.lo-profile (container: /tmp/naabsa-lo)

# === IA (implementação 010 — atrás da flag; off por padrão) ===
AI_ENABLED=false
AI_PROVIDER=anthropic       # anthropic | openai
AI_MODEL=                   # opcional; default por provedor (anthropic: claude-sonnet-4-6, openai: gpt-4o)
ANTHROPIC_API_KEY=          # se AI_PROVIDER=anthropic (e AI_ENABLED=true)
OPENAI_API_KEY=             # se AI_PROVIDER=openai

# === Deploy / Caddy ===
APP_DOMAIN=                 # vazio = HTTP em :80 (local); domínio = TLS automático (produção)
CADDY_HTTP_PORT=80          # porta HTTP publicada no host (local: troque se 80 estiver em uso)
CADDY_HTTPS_PORT=443        # porta HTTPS publicada no host
