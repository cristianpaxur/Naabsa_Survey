# Variáveis de ambiente do Sistema de Relatórios Naabsa (PRD §13).
# Copie para `.env` e preencha. NUNCA commitar o `.env` (está no .gitignore).

# === Supabase ===
SUPABASE_URL=
SUPABASE_ANON_KEY=          # apps/web (cliente)
SUPABASE_SERVICE_ROLE_KEY=  # apps/worker e rotas de serviço

# (Opcional) Espelho para o browser. NÃO é necessário em produção/container: o app
# lê SUPABASE_URL/SUPABASE_ANON_KEY em runtime e injeta a config pública no browser
# (ver apps/web/lib/supabase/config.ts). Útil só como conveniência no dev local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Banco (pg-boss usa o Postgres do Supabase) ===
DATABASE_URL=

# === Geração de PDF (.docx nativo → LibreOffice) ===
APP_BASE_URL=               # OPCIONAL: o logo do PDF é empacotado no worker (apps/worker/assets); APP_BASE_URL é só fallback
SOFFICE_PATH=               # opcional: caminho do soffice (default detecta Windows/Linux)
LO_PROFILE_DIR=             # opcional: perfil do LibreOffice (worker); default ./.lo-profile (container: /tmp/naabsa-lo)

# === IA (implementação 010 — atrás da flag; off por padrão) ===
AI_ENABLED=false
AI_PROVIDER=anthropic       # anthropic | openai
AI_MODEL=                   # opcional; default por provedor (anthropic: claude-sonnet-4-6, openai: gpt-4o)
ANTHROPIC_API_KEY=          # se AI_PROVIDER=anthropic (e AI_ENABLED=true)
OPENAI_API_KEY=             # se AI_PROVIDER=openai

# === Deploy / Caddy ===
APP_DOMAIN=                 # vazio = HTTP em :80 (local); domínio = TLS automático (produção)
CADDY_HTTP_PORT=80          # porta HTTP publicada no host (local: troque se 80 estiver em uso)
CADDY_HTTPS_PORT=443        # porta HTTPS publicada no host

# === Editor nativo Collabora Online / WOPI (impl. 011) ===
WOPI_TOKEN_SECRET=                                    # segredo HMAC do access_token WOPI (gere: openssl rand -hex 32)
COLLABORA_URL=http://localhost:9980                   # base do Collabora p/ o app buscar /hosting/discovery (dev)
WOPI_PUBLIC_URL=http://host.docker.internal:3000      # URL do app que o container Collabora chama de volta (dev)
COLLABORA_ALIASGROUP=http://host.docker.internal:3000 # host WOPI permitido (dev = porta do next dev). Prod: o domínio público (URI válido, sem regex de porta)
COLLABORA_PORT=9980                                   # porta do Collabora publicada no host (dev). Prod: atrás do Caddy
COLLABORA_SSL_TERMINATION=false                       # dev=false (http direto). Prod atrás do Caddy=true
COLLABORA_ADMIN_USER=admin                            # console admin do Collabora (/browser/dist/admin/admin.html)
COLLABORA_ADMIN_PASSWORD=admin
