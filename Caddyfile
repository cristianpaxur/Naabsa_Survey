# Caddy — reverse proxy + TLS automático (PRD §2/§7).
#
# APP_DOMAIN é fornecido pelo docker-compose:
#   ":80"      → escuta em HTTP (ideal para `docker compose up` local);
#   um domínio → Caddy emite/renova TLS automaticamente (produção no VPS).
{$APP_DOMAIN} {
	encode gzip

	# Headers de segurança no proxy (010/T-010, RNF-05) — defesa em profundidade
	# (a app também os emite via next.config). HSTS só tem efeito sob HTTPS.
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		-Server
	}

	# Collabora Online (LibreOffice no browser) — impl. 011. Caddy faz upgrade de WS automático.
	@collabora path /browser/* /hosting/* /cool/* /lool/*
	reverse_proxy @collabora collabora:9980

	reverse_proxy app:3000
}
