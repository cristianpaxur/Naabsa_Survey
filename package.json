{
  "name": "naabsa-survey",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de Relatórios Automatizados Naabsa — monorepo (app, worker, core, db)",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build",
    "dev": "pnpm -r --if-present --parallel run dev",
    "db:migrate": "pnpm --filter @naabsa/db migrate",
    "db:seed-dev": "pnpm --filter @naabsa/db seed:dev",
    "e2e": "dotenv -e .env -- playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@supabase/supabase-js": "^2.47.10",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.18.0",
    "exceljs": "^4.4.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.9"
  }
}
